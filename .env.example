# =========================================================================
# CFA AI TUTOR CONFIGURATION ENVIRONMENT VARIABLES
# Rename this file to '.env' and populate your active API keys.
# =========================================================================

# -----------------
# 1. API Keys (Add keys for whichever providers you want to support)
# -----------------

# Google Gemini API Key (Highly Recommended - Free/Low-cost & Fast)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (Recommended - Blistering, sub-second inference)
# Get a key at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key (Optional)
OPENAI_API_KEY=your_openai_api_key_here

# -----------------
# 2. RAG Orchestration Configs
# -----------------

# Selected active LLM provider. Options: "gemini", "groq", "openai".
# If left blank, it will automatically select the first available key
# in the order: gemini -> groq -> openai.
LLM_PROVIDER=gemini

# Selected vector embedding model provider. Options: "gemini", "openai", "local".
# "local" runs a zero-dependency local text hash algorithm so that the vector 
# store never crashes even if no internet/API keys are available immediately.
EMBEDDING_PROVIDER=local

# -----------------
# 3. Model Engine Version Selection
# -----------------
GEMINI_MODEL=gemini-1.5-flash
GROQ_MODEL=llama3-70b-8192
OPENAI_MODEL=gpt-4-turbo

# -----------------
# 4. Local Deployment Ports
# -----------------
PORT=8000
HOST=0.0.0.0
